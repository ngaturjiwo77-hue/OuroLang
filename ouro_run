#!/bin/bash
# ==========================================
# OURO RUN - Compile & Execute
# ==========================================

INPUT="${1:-input.ouro}"

echo "╔══════════════════════════════════════╗"
echo "║        OURO RUNTIME                 ║"
echo "╚══════════════════════════════════════╝"
echo ""

# 1. Compile (generate bytecode)
echo "[COMPILE] $INPUT"
./native/kernel_compiler < /dev/null 2>/dev/null

# 2. Execute
echo "[EXECUTE]"
./native/vm_arm64

echo ""
echo "[DONE]"
