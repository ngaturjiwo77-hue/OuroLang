#!/bin/bash
# OUROC - Ouro Compiler (Murni Ouro)
# Pakai compiler Ouro Universal untuk compile .ouro → .obf
INPUT="${1:-input.ouro}"
OUTPUT="${2:-output.obf}"
cp "$INPUT" input.ouro
./bin/ouro_vm build/ouroc_universal.obf
cp output.obf "$OUTPUT" 2>/dev/null
echo "[OUROC] $INPUT → $OUTPUT ($(wc -c < "$OUTPUT" 2>/dev/null || echo 0) bytes)"
