PROGRAM_UTAMA
    BAWAKAN "lib/vm.ouro"
    CETAK_TEKS "VM Ouro - Powered by vm.ouro"
    CETAK_TEKS "=============================="
    CETAK_TEKS "[INIT] VM Mulai..."
    SIMPAN OP 0
    TAMBAH OP 61
    CETAK_TEKS "[EXEC] CETAK_TEKS"
    SIMPAN X 10
    SIMPAN Y 20
    TAMBAH_VAR X Y
    CETAK_TEKS "[EXEC] TAMBAH_VAR"
    CETAK_TEKS "Hasil: "
    CETAK_ANGKA X
    CETAK_TEKS "[DONE] VM Selesai"
BATAS_PROGRAM
